# 1. Базовый образ с Python 3.12 (совместим с вашим кодом)
FROM python:3.12-slim

# 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Сначала копируем только файл с зависимостями (это ускоряет сборку)
COPY requirements.txt .

# 4. Устанавливаем все необходимые библиотеки
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем ВЕСЬ остальной код вашего приложения в контейнер
COPY . .

# 6. Указываем порт, который будет "слушать" ваше приложение
EXPOSE 5001

# 7. Команда для запуска приложения (указываем хост 0.0.0.0, чтобы было доступно извне)
CMD ["python", "app.py"]